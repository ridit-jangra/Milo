{
  "name": "@ridit/milo",
  "version": "0.6.2",
  "description": "Tiny cat. Big code.",
  "author": "Ridit Jangra <riditjangra09@gmail.com> (https://ridit.space)",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ridit-jangra/Milo.git"
  },
  "main": "dist/index.mjs",
  "bin": {
    "milo": "dist/index.mjs"
  },
  "scripts": {
    "dev": "bun src/index.tsx",
    "build": "npm run lint && bun build src/index.tsx --target node --outfile dist/index.mjs --external react-devtools-core --external ink --external react --external chalk --external commander --external figures --external ink-spinner",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/index.mjs';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'))\"",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "react-devtools-core": "^7.0.1",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.57",
    "@ai-sdk/groq": "^3.0.33",
    "@ai-sdk/openai": "^3.0.50",
    "@openrouter/ai-sdk-provider": "^2.5.0",
    "@supabase/supabase-js": "^2.104.1",
    "@vscode/ripgrep": "^1.17.1",
    "ai": "^6.0.145",
    "ai-sdk-ollama": "^3.8.2",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cli-truncate": "^5.2.0",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "figures": "^6.1.0",
    "glob": "^13.0.6",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "lodash-es": "^4.18.1",
    "marked": "^17.0.5",
    "react": "^19.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
